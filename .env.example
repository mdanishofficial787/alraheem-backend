# Gmail account used to send booking/quote emails
EMAIL=your-gmail-address@gmail.com
# Gmail App Password (NOT your normal Gmail password) - generate from Google Account > Security > App Passwords
PASSWORD=your-gmail-app-password
# Where quote/booking notification emails should be sent (your business inbox)
TOEMAIL=alraheemtechnologies@gmail.com
# MongoDB Atlas connection string (Database > Connect > Drivers) - used to store consultation bookings
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/alraheem?retryWrites=true&w=majority
